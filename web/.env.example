# ── Sesión (REQUERIDO en producción) ──────────────────────────────────────────
# Firma HMAC de la cookie `urb_session`. Generar con:  openssl rand -hex 32
SESSION_SECRET=

# ── Persistencia (Railway: apuntar a un Volume montado) ───────────────────────
# Si no defines estas vars se usa <cwd>/data y <cwd>/public/uploads (sirve para dev).
# En Railway monta un Volume en /data y pon:
#   URBNBEE_DATA_DIR=/data/json
#   URBNBEE_UPLOADS_DIR=/data/uploads
URBNBEE_DATA_DIR=
URBNBEE_UPLOADS_DIR=

# Promueve a admin al arranque si el usuario ya existe (correo en minúsculas).
# Ej.: URBNBEE_ADMIN_EMAIL=admin@urbnbee.net
URBNBEE_ADMIN_EMAIL=

# ── MySQL (opcional; sin esto la app sigue usando JSON en URBNBEE_DATA_DIR) ────
# URL tipo: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Railway: copia la variable que expone el plugin MySQL (p. ej. MYSQL_URL o DATABASE_URL).
DATABASE_URL=
# Alternativa por variables sueltas:
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=

# ── Integración BeeAgent / URBNBEEAI.com (server-to-server + CORS) ────────────
# Secreto compartido: enviar como Authorization: Bearer <valor> desde urbnbeeai.com.
# Generar: openssl rand -hex 32
URBNBEE_PARTNER_API_SECRET=
# Opcional: firma HMAC de webhooks BeeAgent→Urbnbee (si vacío, usa URBNBEE_PARTNER_API_SECRET).
URBNBEE_PARTNER_WEBHOOK_SECRET=
# Orígenes CORS separados por coma (default: https://urbnbeeai.com,https://www.urbnbeeai.com).
URBNBEE_PARTNER_ORIGINS=

# ── Stripe (requerido para pagos y suscripción de verificación) ───────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Membresía huésped (Price IDs mode subscription). Usa regional MX/US o el par legado.
STRIPE_PRICE_VERIFICATION_MX_MONTHLY=
STRIPE_PRICE_VERIFICATION_MX_ANNUAL=
STRIPE_PRICE_VERIFICATION_US_MONTHLY=
STRIPE_PRICE_VERIFICATION_US_ANNUAL=
# Legado (una sola moneda): si las de arriba están vacías, se usan estas.
STRIPE_PRICE_VERIFICATION_MONTHLY=
STRIPE_PRICE_VERIFICATION_ANNUAL=

# true = además de membresía activa exige KYC verificado (Stripe Identity + webhooks en el mismo endpoint).
STRIPE_IDENTITY_ENABLED=false

# Cargo plataforma sobre el total estancia+limpieza al pagar la reserva (por defecto 1).
PLATFORM_BOOKING_FEE_PERCENT=1
# Opcional: mínimo en MXN si quieres un piso al fee (0 = desactivado).
PLATFORM_BOOKING_FEE_MIN_MXN=0

# ── Blog bot (opcional): generador de posts con LLM ───────────────────────────
# Orden de precedencia: BLOG_BOT_OPENAI_API_KEY → OPENAI_API_KEY → clave guardada en /admin.
BLOG_BOT_OPENAI_API_KEY=
OPENAI_API_KEY=

# Cron (opcional): GET /api/cron/blog-scheduled — Authorization: Bearer … o ?secret=
CRON_SECRET=

# Importación asistida de listings (capturas + visión OpenAI). false para desactivar.
# Si no se define, se habilita cuando hay OPENAI_API_KEY o BLOG_BOT_OPENAI_API_KEY.
LISTING_IMPORT_AI_ENABLED=
# LISTING_IMPORT_OPENAI_MODEL=gpt-4o-mini
# LISTING_IMPORT_TIMEOUT_MS=90000
# LISTING_IMPORT_INPUT_USD_PER_1M=0.15
# LISTING_IMPORT_OUTPUT_USD_PER_1M=0.6
